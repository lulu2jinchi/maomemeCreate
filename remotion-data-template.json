    },
    {
      "id": "audio_1",
      "type": "audio",
      "assetId": "bgm_1",
      "from": 0,
      "duration": 900,
      "trimStart": 0,
      "trimEnd": 0,
      "volume": 0.5,
      "fadeInFrames": 15,
      "fadeOutFrames": 20
