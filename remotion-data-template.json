        "height": 1920,
        "fit": "cover",
        "opacity": 1
      },
      "animation": {
        "enter": "fadeIn",
        "exit": "fadeOut"
      }
    },
    {
      "id": "text_1",
      "type": "text",
      "from": 30,
      "duration": 120,
      "content": "你的字幕",
      "style": {
        "x": 80,
        "y": 1500,
        "maxWidth": 920,
        "fontFamily": "Noto Sans SC",
        "fontSize": 56,
        "fontWeight": 700,
        "lineHeight": 1.3,
        "color": "#ffffff",
        "textAlign": "center"
      },
      "animation": {
        "enter": "slideUp",
        "exit": "fadeOut"
